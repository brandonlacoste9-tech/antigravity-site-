# Ethereum RPC endpoint (required)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional: WebSocket RPC for real-time feeds (preferred for production)
RPC_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Comma-separated Uniswap V3 pool addresses to monitor
# Leave empty to use built-in defaults (USDC/ETH, WBTC/ETH, etc.)
POOL_ADDRESSES=

# Anomaly thresholds
MIN_LIQUIDITY_USD=500000
ZSCORE_THRESHOLD=2.5
FLASH_LOAN_WINDOW_SECONDS=30
FLASH_LOAN_MIN_TX_COUNT=3